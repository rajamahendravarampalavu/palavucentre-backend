NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Cookie settings
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_NAME=palavu_admin_token
USER_COOKIE_NAME=palavu_user_token

# Auth secrets (MUST change in production)
JWT_SECRET=change-me-to-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=7d
CSRF_SECRET=change-me-to-a-long-random-csrf-secret-min-16-chars

# Bootstrap admin (only for initial seed, leave empty after)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Ordering
ORDER_TAX_PERCENT=5
CURRENCY=INR

# Razorpay (leave empty to disable online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth (leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Media uploads
DEFAULT_HERO_MEDIA_URL=/hero-bg.jpg
DEFAULT_LOGO_URL=
MEDIA_DELETE_ON_REMOVE=true
MAX_UPLOAD_IMAGES=50
MAX_UPLOAD_FILE_SIZE_MB=5
MAX_UPLOAD_SOURCE_FILE_SIZE_MB=20
